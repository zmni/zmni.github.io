---
import LogoGelap from "@/assets/logo-gelap.svg";
import LogoTerang from "@/assets/logo-terang.svg";
import { Icon } from "astro-icon/components";

import navigasi from "@/content/data/navigasi.json";

const isHome = Astro.url.pathname === "/";

const isActive = (href: string) => {
  const path = Astro.url.pathname;
  if (href === "/") return path === "/";
  return path.startsWith(href);
};
---

<header
  class:list={[
    isHome ? "fixed inset-0 bottom-auto w-full" : "sticky top-0",
    "z-50",
    "transition",
    isHome ? "data-scrolled:bg-white data-scrolled:shadow" : "bg-white shadow",
  ]}
>
  <div class:list={["container", "flex", "items-center", "p-4", isHome ? "in-data-scrolled:py-2" : "py-2"]}>
    {/* LOGO */}
    <a href="/">
      {
        isHome ? (
          <LogoTerang
            height="1em"
            width="1em"
            class:list={[
              "transition-[font-size]",
              "text-7xl",
              "in-data-scrolled:text-5xl",
              "in-data-scrolled:invert",
              "[view-transition-name:logo]",
            ]}
          />
        ) : (
          <LogoGelap height="1em" width="1em" class="text-5xl [view-transition-name:logo]" />
        )
      }
    </a>

    {/* NAVIGASI */}
    <input id="nav-toggle" type="checkbox" class="peer hidden" />

    <label
      for="nav-toggle"
      class:list={[
        "ml-auto",
        isHome ? "text-gray-200 in-data-scrolled:text-gray-700" : "text-gray-700",
        "flex",
        "items-center",
        "border",
        "border-gray-200",
        "peer-checked:border-blue-500",
        "peer-checked:bg-blue-500",
        "peer-checked:text-white",
        "md:hidden",
      ]}
      aria-label="Klik untuk membuka atau menutup menu navigasi"
    >
      <Icon name="bi:list" size="3rem" class="in-peer-checked:hidden" />
      <Icon name="bi:x-lg" size="3rem" class="hidden in-peer-checked:block" />
    </label>

    <nav
      class:list={[
        "absolute",
        "top-full",
        "right-4",
        "hidden",
        "bg-blue-500",
        "peer-checked:block",
        "md:static",
        "md:top-auto",
        "md:ml-auto",
        "md:flex",
        "md:items-center",
        "md:gap-x-1",
        "md:bg-transparent",
      ]}
    >
      {
        navigasi.map(({ label, href }) => (
          <a
            href={href}
            class:list={[
              "block",
              "px-5 py-3",
              "not-first:border-t",
              "border-gray-200",
              "text-right",
              "text-gray-200",
              "font-medium",
              "transition-colors",
              "hover:text-white",
              "aria-[current]:text-white",
              "md:not-first:border-t-0",
              "md:rounded-sm",
              "md:px-3 md:py-1",
              "md:text-left",
              isHome ? "md:in-data-scrolled:text-gray-700" : "md:text-gray-700",
              "md:hover:bg-blue-500",
              "md:aria-current:bg-blue-500",
            ]}
            aria-current={isActive(href) ? "true" : null}
          >
            {label}
          </a>
        ))
      }
    </nav>
  </div>
</header>

