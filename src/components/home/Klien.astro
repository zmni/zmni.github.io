---
import Section from "@/layouts/Section.astro";
import Img from "@/components/ui/Img.astro";
import { prettyImgAlt } from "@/utils/text";

import { label, deskripsi, data } from "@/content/data/klien.json";
---

<Section id="klien" label={label} deskripsi={deskripsi}>
  <div class="grid grid-cols-2 gap-px bg-gray-200 lg:grid-cols-4">
    {
      data.map((img) => (
        <div class="flex items-center justify-center bg-gray-50 p-4 transition-colors md:p-6 xl:p-16">
          <Img src={img} alt={prettyImgAlt(img)} layout="none" loading="lazy" />
        </div>
      ))
    }
  </div>
</Section>
