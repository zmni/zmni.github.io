---
import { label, deskripsi, data } from "@/content/data/branding.json";
import Hgroup from "@/components/ui/Hgroup.astro";
import Img from "@/components/ui/Img.astro";
import { prettyImgAlt } from "@/utils/text";
---

<section id="branding">
  <Hgroup
    as="h2"
    class="mb-12 text-center"
    hclass="font-black tracking-tighter uppercase text-gray-800 text-2xl lg:text-3xl xl:text-4xl"
  >
    <Fragment slot="label" set:text={label} />
    <Fragment slot="deskripsi" set:text={deskripsi} />
  </Hgroup>

  <div class="grid md:grid-cols-3">
    {
      data.map((item) => (
        <Img src={item} alt={prettyImgAlt(item)} loading="lazy" />
      ))
    }
  </div>
</section>
