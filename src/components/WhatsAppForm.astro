---
import { data } from "@/content/data/kontak.json";
const nomorWhatsApp = data.whatsapp.replace("0", "62");

const twInputSelectTextarea =
  "mt-1 w-full rounded-sm font-normal border border-gray-200 bg-gray-50 px-4 py-3 outline-none focus:ring-2 focus:ring-blue-500";
---

<div
  class="border border-blue-50 bg-white shadow-2xl shadow-blue-500/20 overflow-hidden rounded-md"
  role="form"
  aria-label="Formulir Konsultasi"
>
  <h3 class="border-b border-gray-100 p-4 text-xl font-semibold rounded-t-sm">
    Konsultasikan dengan kami
  </h3>

  <div
    class="p-4 flex flex-col gap-y-4 rounded-b-sm [&_span]:font-semibold [&_span]:text-sm [&_em]:text-red-500"
  >
    <label>
      <span>Nama Anda <em>*</em></span>
      <input
        type="text"
        id="NamaAnda"
        class={twInputSelectTextarea}
        placeholder="Masukkan nama Anda"
        required
      />
    </label>

    <label>
      <span>Asal Instansi <em>*</em></span>
      <select id="AsalInstansi" class={twInputSelectTextarea} required>
        <option value="Individual" selected>Individual</option>
        <option value="Pemerintah">Pemerintah</option>
        <option value="Swasta">Swasta</option>
      </select>
    </label>

    <label id="NamaInstansiWrap" class="hidden">
      <span>Nama Instansi <em>*</em></span>
      <input
        type="text"
        id="NamaInstansi"
        class={twInputSelectTextarea}
        placeholder="Masukkan nama instansi"
      />
    </label>

    <label>
      <span>Apa yang Anda butuhkan? <em>*</em></span>
      <textarea
        id="PesanAnda"
        class={twInputSelectTextarea}
        rows="4"
        placeholder="Tuliskan pesan Anda di sini..."
        required></textarea>
    </label>

    <span id="TeksValidasi" class="text-xs font-semibold text-red-500 italic">(*) wajib diisi</span>

    <a
      id="TombolKirimPesan"
      href={`https://wa.me/${nomorWhatsApp}`}
      class="pointer-events-none block w-full rounded-sm bg-[#25D366] py-4 text-center font-bold text-white opacity-50 shadow-lg hover:bg-[#20ba59]"
      target="_blank">Kirim via WhatsApp</a
    >
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const inputNamaAnda = document.getElementById("NamaAnda") as HTMLInputElement;
    const selectAsalInstansi = document.getElementById("AsalInstansi") as HTMLSelectElement;
    const wrapNamaInstansi = document.getElementById("NamaInstansiWrap") as HTMLElement;
    const inputNamaInstansi = document.getElementById("NamaInstansi") as HTMLInputElement;
    const teksareaPesanAnda = document.getElementById("PesanAnda") as HTMLTextAreaElement;
    const tombolKirimPesan = document.getElementById("TombolKirimPesan") as HTMLAnchorElement;
    const teksValidasi = document.getElementById("TeksValidasi") as HTMLParagraphElement;

    const syncTombolWhatsApp = () => {
      const isOrg =
        selectAsalInstansi.value === "Pemerintah" || selectAsalInstansi.value === "Swasta";

      // Validasi input ada isinya
      const isValid =
        inputNamaAnda.value.trim() !== "" &&
        teksareaPesanAnda.value.trim() !== "" &&
        (!isOrg || inputNamaInstansi.value.trim() !== "");

      // Sesuaikan tombol kirim dan pesan navigasi
      tombolKirimPesan.classList.toggle("opacity-50", !isValid);
      tombolKirimPesan.classList.toggle("pointer-events-none", !isValid);
      teksValidasi.classList.toggle("hidden", isValid);

      if (!isValid) return;

      const teks1 = "Halo Bintang Surya Madani, Semoga Anda sehat dan bahagia.\n\n";
      const teks2 = "Perkenalkan saya,\n";
      const teks3 = `*Nama:* ${inputNamaAnda.value}\n`;
      const teks4 = isOrg ? `*Instansi:* ${inputNamaInstansi.value}\n` : "";
      const teks5 = `*Pesan:* ${teksareaPesanAnda.value}\n\n`;
      const teks6 = "Senang dapat menghubungi Anda. Terima kasih.";

      const teks = teks1 + teks2 + teks3 + teks4 + teks5 + teks6;

      tombolKirimPesan.href = `${tombolKirimPesan.href}?text=${encodeURIComponent(teks)}`;
    };

    const handleVisibility = (): void => {
      const isOrg =
        selectAsalInstansi.value === "Pemerintah" || selectAsalInstansi.value === "Swasta";
      wrapNamaInstansi.classList.toggle("hidden", !isOrg);
      if (!isOrg) inputNamaInstansi.value = "";
      syncTombolWhatsApp();
    };

    // Event Listeners (Tanpa pengecekan null)
    [inputNamaAnda, inputNamaInstansi, teksareaPesanAnda].forEach((el) =>
      el.addEventListener("input", syncTombolWhatsApp),
    );
    selectAsalInstansi.addEventListener("change", handleVisibility);

    // Inisialisasi
    syncTombolWhatsApp();
  });
</script>
