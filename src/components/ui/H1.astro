---
import type { HTMLAttributes } from "astro/types";

type Props = HTMLAttributes<"h1">;

const { class: className, ...props } = Astro.props;
---

<h1
  class:list={[
    "font-black",
    "tracking-tighter",
    "text-gray-800",
    "uppercase",
    "text-3xl lg:text-4xl xl:text-5xl",
    className,
  ]}
  {...props}
>
</h1>
