---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

type Props = {
  src: string;
  alt: string;
  [key: string]: any;
};

const { src, alt, ...rest } = Astro.props as Props;

// glob semua gambar
const images = import.meta.glob<{ default: ImageMetadata }>("/src/assets/**/*.{gif,jpeg,jpg,png,webp}");

// Error kl ga ada
if (!images[src]) {
  throw new Error(`"${src}" tidak ditemukan di dalam glob.`);
}

// fungsi glob async → perlu await
const imageModule = await images[src]();
---

<Image src={imageModule.default} alt={alt} {...rest} />
