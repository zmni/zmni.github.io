---
type Props = {
  href: string;
  class?: string;
};

const { href, class: classList } = Astro.props as Props;
---

<a
  href={href}
  class:list={[
    "inline-flex items-center rounded-sm border border-gray-300 px-4 py-2 font-semibold shadow-xs transition",
    classList,
  ]}><slot /></a
>
