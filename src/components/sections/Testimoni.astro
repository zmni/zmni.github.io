---
import { testimoni } from "@/data/testimoni";
import { Icon } from "astro-icon/components";
import Section from "../layouts/Section.astro";
import { getKontenById } from "@/utils/konten.util";
const konten = getKontenById("testimoni");
---

<Section
  id={konten.id}
  label={konten.label}
  deskripsi={konten.deskripsi}
  class="border-t border-gray-300"
>
  <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3 lg:gap-8">
    {
      testimoni.map((item) => (
        <div class="rounded-md border border-gray-300 bg-white shadow-2xs">
          <blockquote class="p-4 font-serif flex gap-x-2">
            <Icon
              name="bi:quote"
              class="shrink-0 -mt-0.5 text-4xl text-gray-600"
            />
            <p class="md:text-lg">{item.testimoni}</p>
          </blockquote>

          <div class="flex items-center gap-4 rounded-b-md border-t border-gray-300 bg-gray-50 p-4">
            <Icon name="bi:person-square" class="text-6xl text-gray-600" />

            <span class="inline-flex flex-col">
              <span class="font-bold">{item.nama}</span>
              <span class="text-gray-600">{item.perusahaan}</span>
            </span>
          </div>
        </div>
      ))
    }
  </div>
</Section>
