---
import { getKontenById, getKontenByIds } from "@/utils/konten.util";
import { getImagesByFolder } from "@/utils/image.util";
import { Image } from "astro:assets";
import BtnLink from "../ui/BtnLink.astro";
import Section from "../layouts/Section.astro";
const konten = getKontenById("layanan");
const layanan = getKontenByIds(["billboard", "branding", "interior"]);
---

<Section
  id={konten.id}
  label={konten.label}
  deskripsi={konten.deskripsi}
  class="border-t border-gray-300"
>
  <div class="flex flex-col gap-4 lg:flex-row xl:gap-x-8">
    {
      layanan.map((item) => {
        const image = getImagesByFolder(item.id)[0];

        return (
          <div class="flex flex-col rounded-md border border-gray-300 bg-white shadow-xs lg:w-1/3">
            <div class="aspect-video overflow-hidden rounded-t-md">
              <Image
                src={image}
                alt={item.deskripsi}
                class="w-full h-full object-cover object-center"
                widths={[420, 640, 768]}
                sizes={`(max-width: 639px) 640px, (max-width: 767px) 768px, 420px`}
                loading="lazy"
              />
            </div>

            <div class="p-4">
              <h3>{item.label}</h3>
              <p class="mt-2">{item.deskripsi}</p>
            </div>

            <div class="mt-auto p-4">
              <BtnLink
                href={`/${item.id}/`}
                class="bg-blue-500 hover:bg-blue-600 text-white"
              >
                Informasi selengkapnya
              </BtnLink>
            </div>
          </div>
        );
      })
    }
  </div>
</Section>
