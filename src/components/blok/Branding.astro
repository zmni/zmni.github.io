---
import Hgroup from "@/components/ui/Hgroup.astro";
import { id, label, deskripsi, data } from "@/content/data/branding.json";
import Img from "@/components/ui/Img.astro";
import { prettyImgAlt } from "@/utils/text";
---

<section {id}>
  <Hgroup as="h2" {label} {deskripsi} />

  <div class="grid md:grid-cols-3">
    {data.map((src) => <Img {src} alt={prettyImgAlt(src)} width={1024} />)}
  </div>
</section>
