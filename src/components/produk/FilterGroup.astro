---
import { slugify } from "@/utils/text";

type Props = {
  label: string;
  key: string; // data-filter-group key
  type?: "select" | "radio";
  options: string[];
  currentValue?: string; // For setting 'selected' or 'checked'

  // Navigation props (optional)
  isNavigation?: boolean;
  navBaseUrl?: string; // e.g. '/produk/area/'
  customOnChange?: string; // Raw JS for onchange attribute
};

const {
  label,
  key,
  type = "select",
  options,
  currentValue = "",
  isNavigation = false,
  navBaseUrl,
  customOnChange,
} = Astro.props;

// Determine onchange behavior for navigation selects
const onChangeAttr = customOnChange
  ? customOnChange
  : isNavigation && navBaseUrl
    ? `if(this.value) window.location.href='${navBaseUrl}' + this.value + '/'`
    : undefined;
---

<li class="relative flex items-center gap-x-2" data-role="filter-group" data-filter-group={key}>
  <span class="flex items-center font-bold">
    {label}
  </span>

  {
    type === "select" ? (
      <select
        name={key}
        class="cursor-pointer rounded-md border-2 border-gray-200 bg-white px-2 py-1.5 transition-colors hover:border-blue-500 focus:outline-blue-500"
        data-group={!isNavigation ? key : undefined}
        aria-label={`Filter berdasarkan ${label}`}
        onchange={onChangeAttr}
      >
        <option value="" selected={currentValue === "" || currentValue === undefined}>
          Semua
        </option>
        {options.map((value) => {
          // For navigation, we might want to slugify the value for the URL
          const optionValue = isNavigation ? slugify(value) : value;
          const isSelected = isNavigation ? slugify(currentValue) === optionValue : currentValue === value;

          return (
            <option value={optionValue} selected={isSelected}>
              {value}
            </option>
          );
        })}
      </select>
    ) : (
      <>
        <label class="cursor-pointer rounded-md border-2 border-transparent bg-white px-2 py-1 transition-colors hover:border-blue-500 has-checked:border-gray-200 has-checked:hover:border-blue-500">
          <input
            type="radio"
            name={key}
            value=""
            class="sr-only"
            data-group={key}
            checked={currentValue === "" || currentValue === undefined}
          />
          <span>Semua</span>
        </label>
        {options.map((value) => (
          <label class="cursor-pointer rounded-md border-2 border-gray-100 bg-white px-2 py-1 transition-colors hover:border-blue-500 has-checked:border-gray-200 has-checked:hover:border-blue-500">
            <input
              type="radio"
              name={key}
              value={value}
              class="sr-only"
              data-group={key}
              checked={currentValue === value}
            />
            <span>{value}</span>
          </label>
        ))}
      </>
    )
  }
</li>
