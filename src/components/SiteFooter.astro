---
import bsm from "@/content/data/bsm.json";

const copyright = `&copy; ${new Date().getFullYear()} ${bsm.label}. Semua hak dilindungi.`;
---

<footer
  id="site-footer"
  class="mt-auto border-t border-gray-200 text-center [view-transition-name:site-footer]"
>
  <div class="container py-4">
    <Fragment set:html={copyright} />
  </div>
</footer>
