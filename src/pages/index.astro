---
import BaseLayout from "@/layouts/BaseLayout.astro";

import Intro from "@/components/blok/Intro.astro";
import Layanan from "@/components/blok/Layanan.astro";
import Portofolio from "@/components/blok/Portofolio.astro";
import Klien from "@/components/blok/Klien.astro";
import Kontak from "@/components/blok/Kontak.astro";
import Testimoni from "@/components/blok/Testimoni.astro";
import Branding from "@/components/blok/Branding.astro";

import { label, deskripsi } from "@/content/data/bsm.json";
---

<BaseLayout {label} {deskripsi}>
  <main id="site-main">
    <Intro />
    <Layanan />
    <Branding />
    <Portofolio />
    <Klien />
    <Testimoni />
    <Kontak />
  </main>
</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const header = document.getElementById("site-header");
    const headerFixed = header?.classList.contains("fixed");
    const headerSticky = header?.classList.contains("sticky");
    const headerHeight = headerFixed || headerSticky ? (header?.offsetHeight ?? 0) : 0;
    const navToggle = document.getElementById("site-nav-toggle") as HTMLInputElement | null;

    type NavEntry = { id: string; link: HTMLAnchorElement; section: HTMLElement };
    const navEntries: NavEntry[] = [];

    let isScrolling = false;
    let scrollTimer: ReturnType<typeof setTimeout> | null = null;

    const setScrolling = () => {
      isScrolling = true;
      if (scrollTimer) clearTimeout(scrollTimer);
      scrollTimer = setTimeout(() => {
        isScrolling = false;
      }, 1000);
    };

    document.querySelectorAll<HTMLAnchorElement>("#site-header a").forEach((link) => {
      const href = link.getAttribute("href") ?? "";
      const id = href === "/" ? "intro" : href.startsWith("/#") ? href.slice(2) : null;
      if (!id) return;

      const section = document.getElementById(id);
      if (section) {
        navEntries.push({ id, link, section });

        link.addEventListener("click", (event: MouseEvent) => {
          event.preventDefault();

          setScrolling();

          const hash = id === "intro" ? "" : `#${id}`;
          window.history.pushState(null, "", window.location.pathname + hash);

          const top = section.getBoundingClientRect().top + window.scrollY - headerHeight;
          window.scrollTo({ top, behavior: "smooth" });

          if (navToggle && navToggle.checked) navToggle.checked = false;
        });
      }
    });

    const setActiveLink = () => {
      const threshold = window.innerHeight * 0.4;
      let activeId: string | null = null;

      navEntries.forEach(({ id, section }) => {
        const rect = section.getBoundingClientRect();

        if (rect.top <= threshold && rect.bottom >= headerHeight) {
          activeId = id;
        }
      });

      navEntries.forEach(({ id, link }) => {
        link.classList.toggle("is-active", id === activeId);
      });

      if (activeId && !isScrolling) {
        const hash = activeId === "intro" ? "" : `#${activeId}`;

        if (window.location.hash !== hash) {
          window.history.replaceState(null, "", window.location.pathname + hash);
        }
      }
    };

    if (window.location.hash) {
      const id = window.location.hash.slice(1);
      const section = document.getElementById(id);

      if (section) {
        setScrolling();

        setTimeout(() => {
          const top = section.getBoundingClientRect().top + window.scrollY - headerHeight;
          window.scrollTo({ top, behavior: "smooth" });
        }, 50);
      }
    }

    window.addEventListener(
      "scroll",
      () => {
        if (scrollTimer) clearTimeout(scrollTimer);
        scrollTimer = setTimeout(setActiveLink, 100);
      },
      {
        passive: true,
      },
    );

    setActiveLink();
  });
</script>

<script>
  const kontakSection = document.getElementById("kontak");
  const whatsAppButton = document.getElementById("whatsapp-button") as HTMLAnchorElement | null;

  if (kontakSection && whatsAppButton) {
    const handleIntersection = (entries: IntersectionObserverEntry[]) => {
      const [entry] = entries;

      if (entry.isIntersecting) {
        whatsAppButton.classList.remove("block");
        whatsAppButton.classList.add("hidden");
      } else {
        whatsAppButton.classList.remove("hidden");
        whatsAppButton.classList.add("block");
      }
    };

    const observer = new IntersectionObserver(handleIntersection, {
      root: null,
      rootMargin: "0px",
      threshold: 0.1,
    });

    observer.observe(kontakSection);
  }
</script>
