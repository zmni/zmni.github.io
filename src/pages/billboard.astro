---
import PageLayout from "@/layouts/PageLayout.astro";
import { Icon } from "astro-icon/components";
import { Image } from "astro:assets";

import { produk } from "@/data/produk";
import { navigasi } from "@/data/navigasi";

import { getKontenByPath } from "@/utils/konten.util";
import { getImagesByPrefix } from "@/utils/image.util";

const konten = getKontenByPath(Astro.url.pathname);

const twFilterNavItem =
  "rounded-t-sm border-2 border-transparent p-2 peer-checked:border-gray-300 peer-checked:border-b-gray-100 peer-checked:text-blue-500 hover:text-blue-500 sm:px-4";
const twFilterRadio = "js-filter-link peer sr-only";

const twModalBtnClass =
  "cursor-pointer p-2 text-4xl text-white focus-visible:outline-0";
const twModalBtnNavClass = `${twModalBtnClass} disabled:cursor-not-allowed disabled:opacity-25`;
const twModalBtnCloseClass = `${twModalBtnClass} fixed top-0 right-0`;

import fallbackImage from "@/assets/beranda/fallback.jpg";
---

<PageLayout>
  <nav
    class="mb-4 flex justify-center gap-4 border-b-2 border-gray-300 font-bold xl:mb-8"
  >
    <div class="flex -mb-0.5">
      <span class="inline-flex items-center">
        <input
          id="u-semua"
          name="ukuran"
          value="semua"
          type="radio"
          class={twFilterRadio}
        />
        <label for="u-semua" class={twFilterNavItem}>Semua</label>
      </span>
      {
        navigasi.map((item) => {
          if (!item.subnav) return;
          return item.subnav.map((u) => (
            <span class="inline-flex items-center">
              <input
                id={`u-${u.id}`}
                name="ukuran"
                value={u.id}
                type="radio"
                class={twFilterRadio}
              />
              <label for={`u-${u.id}`} class={twFilterNavItem}>
                {u.id}
              </label>
            </span>
          ));
        })
      }
    </div>
  </nav>

  <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-4 xl:gap-8">
    {
      produk.map((item, i) => {
        const fotoProduk = getImagesByPrefix(konten.id, item.id);
        const mainImage =
          fotoProduk && fotoProduk.length > 0 ? fotoProduk[0] : fallbackImage;

        return (
          <a
            data-index={i}
            data-provinsi={item.provinsi}
            data-kota={item.kota}
            data-ukuran={item.ukuran}
            class="js-produk-item hidden aspect-4/3 cursor-pointer overflow-hidden rounded-md border border-gray-300 opacity-100 shadow-xs transition hover:border-gray-400 [&.hidden]:pointer-events-none"
          >
            <Image
              src={mainImage}
              alt={item.label}
              width={400}
              loading="lazy"
              class="h-full w-full object-cover object-center opacity-100 blur-none transition hover:scale-102 hover:opacity-80 starting:opacity-0 starting:blur-sm"
            />

            <Image
              src={mainImage}
              alt={item.label}
              width={1024}
              loading="lazy"
              class="hidden h-full w-full object-cover object-center opacity-100 blur-none transition starting:opacity-0 starting:blur-sm [&.hidden]:pointer-events-none"
              data-role="produk-foto"
            />
          </a>
        );
      })
    }
  </div>
</PageLayout>

<dialog
  data-role="modal"
  class="m-auto max-h-[calc(100dvh-2rem)] w-full max-w-none overflow-hidden bg-transparent opacity-0 transition transition-discrete not-open:hidden backdrop:bg-black/80 backdrop:opacity-0 backdrop:backdrop-blur-xs backdrop:transition backdrop:transition-discrete open:flex open:items-center open:opacity-100 open:backdrop:opacity-100 starting:open:opacity-0 starting:open:backdrop:opacity-0"
  closedby="any"
>
  <button
    data-role="modal-prev"
    class={twModalBtnNavClass}
    aria-label="Billboard sebelumnya"
  >
    <Icon name="bi:chevron-left" />
  </button>

  <div
    class="max-h-[calc(100dvh-2rem)] grow overflow-hidden rounded-md bg-white lg:flex"
  >
    <div data-role="modal-foto" class="lg:w-2/3 overflow-hidden"></div>
    <div
      data-role="modal-info"
      class="lg:w-1/3 px-4 py-2 lg:px-6 lg:py-4 lg:overflow-y-auto"
    >
    </div>
  </div>

  <button
    data-role="modal-next"
    class={twModalBtnNavClass}
    aria-label="Billboard selanjutnya"
  >
    <Icon name="bi:chevron-right" />
  </button>

  <button
    data-role="modal-close"
    class={twModalBtnCloseClass}
    aria-label="Tutup detail billboard"
  >
    <Icon name="bi:x" />
  </button>
</dialog>

<script
  is:inline
  type="aplication/json"
  id="produk-json"
  set:html={JSON.stringify(produk)}
/>

<script>
  import { $, $$ } from "@/utils/selector.util";
  import { capitalize } from "@/utils/text.util";

  /**
   * =========================
   * Filter state (sumber kebenaran)
   * =========================
   */
  type FilterKey = "provinsi" | "kota" | "ukuran";

  type FilterValue = Record<FilterKey, string | null>;

  const params = new URLSearchParams(window.location.search);

  let filterValue: FilterValue = {
    provinsi: params.get("provinsi"),
    kota: params.get("kota"),
    ukuran: params.get("ukuran"),
  };

  /**
   * =========================
   * Referensi DOM
   * =========================
   */
  const produkItems = $$<HTMLElement>(".js-produk-item");
  const filterLinks = $$<HTMLInputElement>(".js-filter-link");

  /**
   * =========================
   * Derived state
   * =========================
   */
  const getFilteredItems = (): HTMLElement[] =>
    produkItems.filter((item) => !item.classList.contains("hidden"));

  /**
   * =========================
   * Terapkan filter produk ke DOM
   * =========================
   */
  const applyProdukFilter = (): void => {
    produkItems.forEach((item) => {
      let tampil = true;

      (Object.keys(filterValue) as FilterKey[]).forEach((key) => {
        const value = filterValue[key];
        if (value && item.dataset[key] !== value) {
          tampil = false;
        }
      });

      item.classList.toggle("hidden", !tampil);
    });
  };

  /**
   * =========================
   * Update nav aktif (per key)
   * =========================
   */
  const updateNavActiveState = (): void => {
    filterLinks.forEach((el) => {
      const key = el.name as FilterKey;
      const value = el.value;

      const aktif =
        (value === "semua" && filterValue[key] === null) ||
        filterValue[key] === value;

      el.toggleAttribute("checked", aktif);
    });
  };

  /**
   * =========================
   * Sinkronkan URL dan riwayat
   * =========================
   */
  const updateURLHistorySync = (): void => {
    const url = new URL(window.location.href);

    (Object.keys(filterValue) as FilterKey[]).forEach((key) => {
      const value = filterValue[key];
      if (value) url.searchParams.set(key, value);
      else url.searchParams.delete(key);
    });

    history.replaceState(filterValue, "", url);
  };

  /**
   * =========================
   * Produk data
   * =========================
   */
  type ProdukData = Record<string, string | number | null>;
  const produkData: ProdukData[] = JSON.parse($("#produk-json")!.textContent!);

  /**
   * =========================
   * Elemen modal
   * =========================
   */
  const modal = $<HTMLDialogElement>('[data-role="modal"]')!;
  const modalFoto = $<HTMLDivElement>('[data-role="modal-foto"]', modal)!;
  const modalInfo = $<HTMLDivElement>('[data-role="modal-info"]', modal)!;

  const modalBtnPrev = $<HTMLButtonElement>('[data-role="modal-prev"]', modal)!;
  const modalBtnNext = $<HTMLButtonElement>('[data-role="modal-next"]', modal)!;
  const modalBtnClose = $<HTMLButtonElement>(
    '[data-role="modal-close"]',
    modal,
  )!;

  let currentIndex = 0;

  /**
   * =========================
   * Helper modal
   * =========================
   */
  const cloneProdukFoto = (item: HTMLElement): HTMLImageElement => {
    const img = item.querySelector<HTMLImageElement>(
      '[data-role="produk-foto"]',
    )!;
    const clone = img.cloneNode(true) as HTMLImageElement;
    clone.classList.remove("hidden");
    return clone;
  };

  const renderModalInfo = (produkIndex: number): string => {
    const data = produkData[produkIndex];
    if (!data) return "";

    return Object.entries(data)
      .map(([key, value]) => {
        const label =
          key === "lat"
            ? "Latitude"
            : key === "lng"
              ? "Longitude"
              : capitalize(key);

        return `
        <div class="flex border-b border-gray-300 py-2">
          <span class="font-bold min-w-20">${label}</span>
          <span>:</span>
          <span class="flex-1 pl-1">${value ?? "-"}</span>
        </div>
      `;
      })
      .join("");
  };

  const renderModal = (index: number): void => {
    const items = getFilteredItems();
    const item = items[index];
    if (!item) return;

    modalFoto.replaceChildren(cloneProdukFoto(item));
    modalInfo.innerHTML = renderModalInfo(Number(item.dataset.index));

    currentIndex = index;
    modalBtnPrev.disabled = index <= 0;
    modalBtnNext.disabled = index >= items.length - 1;

    modal.showModal();
  };

  /**
   * =========================
   * Event bindings
   * =========================
   */

  // Multi-nav filter (GENERIC)
  filterLinks.forEach((el) => {
    el.addEventListener("change", (e) => {
      const key = el.name as FilterKey;
      const value = el.value;

      filterValue = {
        ...filterValue,
        [key]: value === "semua" ? null : value,
      };

      updateNavActiveState();
      applyProdukFilter();
      updateURLHistorySync();
      currentIndex = 0;
    });
  });

  // Produk click
  produkItems.forEach((item) => {
    item.addEventListener("click", (e) => {
      e.preventDefault();
      if (item.classList.contains("hidden")) return;

      const items = getFilteredItems();
      const index = items.indexOf(item);
      if (index >= 0) renderModal(index);
    });
  });

  // Modal controls
  modalBtnClose.addEventListener("click", () => modal.close());

  modalBtnPrev.addEventListener("click", () => {
    if (currentIndex > 0) renderModal(currentIndex - 1);
  });

  modalBtnNext.addEventListener("click", () => {
    const max = getFilteredItems().length - 1;
    if (currentIndex < max) renderModal(currentIndex + 1);
  });

  // Keyboard
  document.addEventListener("keydown", (e) => {
    if (!modal.open) return;

    if (e.key === "ArrowLeft" && currentIndex > 0) {
      renderModal(currentIndex - 1);
    }

    if (e.key === "ArrowRight") {
      const max = getFilteredItems().length - 1;
      if (currentIndex < max) renderModal(currentIndex + 1);
    }
  });

  // Touch / swipe
  let touchStartX = 0;
  let touchEndX = 0;
  const minSwipeDistance = 50;

  const handleSwipe = (): void => {
    const distance = touchEndX - touchStartX;
    const max = getFilteredItems().length - 1;

    if (distance > minSwipeDistance && currentIndex > 0) {
      renderModal(currentIndex - 1);
    }

    if (distance < -minSwipeDistance && currentIndex < max) {
      renderModal(currentIndex + 1);
    }
  };

  modal.addEventListener(
    "touchstart",
    (e) => {
      touchStartX = e.changedTouches[0].screenX;
    },
    { passive: true },
  );

  modal.addEventListener(
    "touchend",
    (e) => {
      touchEndX = e.changedTouches[0].screenX;
      handleSwipe();
    },
    { passive: true },
  );

  /**
   * =========================
   * Init
   * =========================
   */
  updateNavActiveState();
  applyProdukFilter();
</script>

<style>
  body {
    overflow-y: scroll;
  }
</style>
