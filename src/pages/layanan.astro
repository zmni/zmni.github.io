---
import { getKontenByIds } from "@/utils/konten.util";
import { getImagesByFolder } from "@/utils/image.util";

import PageLayout from "@/layouts/PageLayout.astro";
import { Image } from "astro:assets";
import BtnLink from "@/components/ui/BtnLink.astro";

const konten = getKontenByIds(["billboard", "branding", "interior"]);
---

<PageLayout>
  <div class="flex flex-col gap-12">
    {
      konten.map((item, i) => {
        const isEven = i % 2 === 0;
        const image = getImagesByFolder(item.id)[0];

        return (
          <div
            class={`flex ${isEven ? "flex-row" : "flex-row-reverse"} rounded-md overflow-hidden border border-gray-300 bg-white shadow-xs`}
          >
            <div
              class={`aspect-video overflow-hidden w-2/3 ${isEven ? "rounded-l-md" : "rounded-r-md"}`}
            >
              <Image
                src={image}
                alt={item.deskripsi}
                widths={[420, 640, 768]}
                sizes={`(max-width: 639px) 640px, (max-width: 767px) 768px, 420px`}
                class="w-full h-full object-cover object-center"
                loading="lazy"
              />
            </div>

            <div
              class={`flex flex-col p-4 lg:p-8 w-1/3${!isEven ? " text-right" : ""}`}
            >
              <h2>{item.label}</h2>
              <p class="my-4">{item.deskripsi}</p>

              <BtnLink
                href={`/${item.id}/`}
                class={`bg-blue-500 hover:bg-blue-600 text-white mt-auto ${isEven ? "self-start" : "self-end"}`}
              >
                Informasi selengkapnya
              </BtnLink>
            </div>
          </div>
        );
      })
    }
  </div>
</PageLayout>
