---
import BaseLayout from "./BaseLayout.astro";
import Hgroup from "@/components/ui/Hgroup.astro";

type Props = {
  label: string;
  deskripsi: string;
  ogImage?: string;
};

const { label, deskripsi, ogImage } = Astro.props;
---

<BaseLayout label={`${label} - Bintang Surya Madani`} deskripsi={deskripsi} ogImage={ogImage}>
  <main class="container py-12 lg:py-24">
    <Hgroup label={label} deskripsi={deskripsi} />

    <slot />
  </main>
</BaseLayout>
