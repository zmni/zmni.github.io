---
import BaseLayout from "./BaseLayout.astro";
import Hgroup from "@/components/ui/Hgroup.astro";

type Props = {
  label: string;
  deskripsi: string;
  ogImage?: string;
};

const { label, deskripsi, ogImage } = Astro.props;
---

<BaseLayout label={`${label} - Bintang Surya Madani`} {deskripsi} {ogImage}>
  <main id="site-main" class="container py-12">
    <Hgroup as="h1" {label} {deskripsi} />

    <slot />
  </main>
</BaseLayout>
